{
  "name": "@takosjp/yurumeet",
  "version": "0.1.0",
  "license": "GPL-3.0-only",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bunx vite --config vite.config.ts",
    "dev:site": "bunx serve site",
    "check": "tsc --noEmit",
    "build": "bunx vite build --config vite.config.ts",
    "lint": "bun run check",
    "fmt": "bunx prettier --write index.html vite.config.ts src site README.md",
    "fmt:check": "bunx prettier --check index.html vite.config.ts src site README.md"
  },
  "dependencies": {
    "@takosjp/yurucommu-api": "^2.0.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.1",
    "vite-plugin-solid": "^2.11.0"
  }
}
