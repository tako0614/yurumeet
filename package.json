{
  "name": "@takosjp/yurumeet",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bunx vite --config vite.config.ts",
    "dev:mock": "bun scripts/dev-mock.ts",
    "dev:mock:api": "bun scripts/dev-mock-server.ts",
    "dev:site": "bunx serve site",
    "check": "tsc --noEmit",
    "build": "bun run build:client",
    "build:client": "bunx vite build --config vite.config.ts",
    "build:takos-worker": "bun scripts/build-takos-worker.ts",
    "takosumi:release": "bun scripts/takosumi-release.ts",
    "lint": "bun run check",
    "fmt": "bunx prettier --write index.html vite.config.ts src site scripts README.md",
    "fmt:check": "bunx prettier --check index.html vite.config.ts src site scripts README.md"
  },
  "dependencies": {
    "@takosjp/yurucommu-api": "^3.0.0",
    "@takosjp/yurucommu-core": "^3.0.1",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260420.1",
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.7.0",
    "vite": "^6.4.1",
    "vite-plugin-solid": "^2.11.0",
    "wrangler": "^4.103.0"
  }
}
